# ============================================================================
# STREAM1 configuration (LOCAL / OFFLINE build).
# Everything here is OPTIONAL — the app runs fully local and generates its own
# secrets into the chosen database folder. Copy to ".env" only if you need to
# override defaults or enable YouTube. Never commit the real .env.
# ============================================================================

# --- Web server (optional) ----------------------------------------------------
# Port the local app/API listens on. Default 15000.
# PORT=15000

# Port the bundled local MongoDB listens on (127.0.0.1 only). Default 15001.
# MONGO_PORT=15001

# Skip the "choose database folder" prompt and reuse the remembered folder.
# (The companion app exe sets this automatically.)
# STREAM1_NO_PROMPT=1

# Force a specific database folder instead of prompting.
# STREAM1_DATA_DIR=C:\STREAM1 Data

# Point at a specific mongod binary (otherwise vendor/mongodb/bin or PATH is used).
# MONGOD_PATH=C:\Program Files\MongoDB\Server\7.0\bin\mongod.exe

# Point at yt-dlp for past stream recording downloads (otherwise vendor/yt-dlp/yt-dlp.exe).
# Run once: npm run fetch:ytdlp
# STREAM1_YTDLP_PATH=C:\azure\stream1\vendor\yt-dlp\yt-dlp.exe

# Point at ffmpeg for the Facebook simulcast relay (otherwise vendor/ffmpeg/ffmpeg.exe).
# Run once: npm run fetch:ffmpeg
# STREAM1_FFMPEG_PATH=C:\azure\stream1\vendor\ffmpeg\ffmpeg.exe

# --- Google / YouTube (only needed to enable streaming) -----------------------
# From Google Cloud Console → Credentials → OAuth client (type: Web application),
# with YouTube Data API v3 enabled and redirect URI http://localhost:15000/oauth2callback
#
# For packaged builds, place this file as ".env" in EITHER location:
#   1. Next to STREAM1 Server.exe (same folder as the exe)
#   2. Inside your STREAM1 database/data folder
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
#
# For email stream links (Settings → Email connection), also add redirect URI
# http://localhost:15000/gmail/oauth2callback and enable the Gmail API.

# --- ClickSend SMS (stream link sharing via Text button) ----------------------
# From dashboard.clicksend.com → API Credentials. Place .env next to
# STREAM1 Server.exe (or in your data folder). Reload env in Diagnostics after changes.
# CLICKSEND_USERNAME=
# CLICKSEND_API_KEY=
# CLICKSEND_FROM=          # optional sender ID (alpha tag or dedicated number)

# --- Facebook (only needed to enable Facebook simulcasting) -------------------
# From developers.facebook.com → your app → Settings → Basic. Add
# http://localhost:15000/facebook/oauth2callback to "Valid OAuth Redirect URIs"
# (Facebook Login product). App needs pages_show_list, pages_read_engagement,
# pages_manage_posts and publish_video permissions (App Review required for
# accounts outside the app's admins/developers/testers).
# FACEBOOK_APP_ID=
# FACEBOOK_APP_SECRET=
# FACEBOOK_GRAPH_VERSION=v19.0

# --- Restream (only needed for Restream mode: ATEM → Restream → platforms) ----
# From developers.restream.io → Applications → Create New. Add
# http://localhost:15000/restream/oauth2callback as a Redirect URI and tick the
# profile/channels/stream read+write scopes. Credentials can also be pasted in
# the app's Settings page instead of here.
# RESTREAM_CLIENT_ID=
# RESTREAM_CLIENT_SECRET=

# --- Secrets (optional — auto-generated per data folder if omitted) -----------
# SESSION_SECRET and TOKEN_ENCRYPTION_KEY are created automatically and stored in
# <data folder>/stream1-secrets.json. Set them here only to pin specific values.
# SESSION_SECRET=
# TOKEN_ENCRYPTION_KEY=

# STREAM1_CONTROL_TABLET_URL=http://192.168.0.108:8000/tablet
# STREAM1_VOLUME_CONTROL_URL=http://192.168.0.201/uci-viewer/?uci=TSC&file=1.UCI.xml&directory=/designs/current_design/UCIs/
# Use http:// for most LAN gear unless the device truly serves HTTPS.

# --- One-time user seeding (scripts/seed-users.js) ---------------------------
# Never commit real passwords. Used by: npm run seed:users
# STREAM1_SEED_ADMIN_PASSWORD=
# STREAM1_SEED_VIEWER_PASSWORD=

# --- Developer publish settings (your PC only — never on church PCs) -----------
# Git push uses browser login; publishing releases needs a separate API token.
# Create at https://github.com/settings/tokens/new  (Classic → repo scope)
# GITHUB_TOKEN=ghp_xxxxxxxx
# STREAM1_GITHUB_REPO=davidcarlino/Stream1

# --- Auto-updates (optional — packaged builds only) ---------------------------
# Point at a HTTPS JSON manifest (latest.json). Set this once — it never changes.
# STREAM1_UPDATE_MANIFEST_URL=https://github.com/davidcarlino/Stream1/releases/download/latest/latest.json
# STREAM1_DISABLE_UPDATES=1
#
# Publishing (developer machine only):
# STREAM1_GITHUB_REPO=davidcarlino/Stream1

# --- Windows code signing (optional — npm run cert:signing) -------------------
# Self-signed dev cert: certs/stream1-codesign.pfx  password stream1-dev
# STREAM1_SIGN_PFX=C:\azure\stream1\certs\stream1-codesign.pfx
# STREAM1_SIGN_PASSWORD=stream1-dev
